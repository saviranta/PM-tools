# ===================
# PM-tools .gitignore
# LLM workflows and agents for product management
# ===================

# ----- Credentials & Secrets -----
.env
.env.*
!.env.example
*.env
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/
credentials/
api_keys.json
*api_key*
*apikey*
*access_token*
*secret_key*
service_account*.json
*_credentials.json
*_secret*.json
auth_token*
token.json
oauth*.json
config.local.*
.netrc
.htpasswd
mcp-auth*
mcp-needs-auth*
.openai
.anthropic

# ----- Personal & Persona Data -----
# CV and career assets
assets/work_experience.*
assets/capabilities*
assets/accomplishments*
assets/motivators.*
assets/profiles.*
assets/personality*
assets/writing_style.*
assets/education.*
assets/languages.*
assets/coverletter_phrases.*
assets/qualities*
personal/
persona/
*_personal.*
# Application outputs (contain personal narrative)
output/
outputs/
applications/
# Personal documents
*.pdf
!docs/**/*.pdf
# Personal images and photos
*.jpg
*.jpeg
*.png
*.gif
!docs/**/*.png
!docs/**/*.jpg
linkedin_*.md
jobad.*

# ----- Collected & Proprietary Data -----
*.db
*.sqlite
*.sqlite3
data/raw/
data/collected/
data/scraped/
data/listings/
data/personal/
*.parquet
*.feather
*.pkl
*.pickle
db_config*
database.yml
database.yaml
*_dump.sql
*.backup

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
env/
.conda/
*.conda

# ----- Node.js -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.pnp.*

# ----- Jupyter Notebooks -----
.ipynb_checkpoints/
*.ipynb_meta/

# ----- IDE & Editors -----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
*.sublime-*

# ----- macOS -----
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ----- LLM & Agent Specific -----
# Model files (too large for git)
*.bin
*.gguf
*.safetensors
*.onnx
models/
checkpoints/

# Logs and outputs
logs/
*.log
outputs/
results/
runs/

# Cache directories
.cache/
.langchain/
.llamaindex/
__llm_cache__/

# Vector stores / embeddings (regenerate locally)
*.faiss
*.pkl
chroma_db/
qdrant_storage/
vector_store/

# Temporary and scratch files
tmp/
temp/
scratch/
drafts/

# ----- Data -----
# Keep data out of git (use separate data management)
data/
!data/.gitkeep
*.csv
*.json
!package.json
!package-lock.json
!tsconfig.json
!*.config.json

# ----- Testing -----
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
